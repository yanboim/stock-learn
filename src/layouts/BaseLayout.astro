---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = '股票学习站', description = '系统化学习股票投资：技术分析、行业研究、交易系统' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900">
          <span class="text-2xl">📈</span>
          <span>股票学习站</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href="/" class="text-gray-600 hover:text-gray-900 transition">首页</a>
          <a href="/tutorials" class="text-gray-600 hover:text-gray-900 transition">教程</a>
          <a href="/tutorials?cat=技术指标" class="text-gray-600 hover:text-gray-900 transition">技术指标</a>
          <a href="/tutorials?cat=行业研究" class="text-gray-600 hover:text-gray-900 transition">行业研究</a>
          <a href="/tutorials?cat=交易系统" class="text-gray-600 hover:text-gray-900 transition">交易系统</a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
        <div class="px-4 py-3 space-y-2">
          <a href="/" class="block py-2 text-gray-600">首页</a>
          <a href="/tutorials" class="block py-2 text-gray-600">教程</a>
          <a href="/tutorials?cat=技术指标" class="block py-2 text-gray-600">技术指标</a>
          <a href="/tutorials?cat=行业研究" class="block py-2 text-gray-600">行业研究</a>
          <a href="/tutorials?cat=交易系统" class="block py-2 text-gray-600">交易系统</a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-5xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-sm text-gray-500">
            📈 股票学习站 · 系统化学习投资知识
          </div>
          <div class="text-xs text-gray-400">
            ⚠️ 本站内容仅供学习交流，不构成投资建议。投资有风险，入市需谨慎。
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
