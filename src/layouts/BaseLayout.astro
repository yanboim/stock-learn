---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  /** Open Graph / Twitter 分享卡片图，相对路径或绝对 URL */
  ogImage?: string;
  /** 覆盖 canonical URL，默认用当前页面路径 */
  canonical?: string;
  /** 页面类型：website / article */
  type?: 'website' | 'article';
  /** 文章发布时间（ISO 字符串），仅 article 类型用 */
  publishedTime?: string;
}

const SITE_NAME = '股票学习站';
const {
  title,
  description = '系统化学习股票投资：技术分析、行业研究、交易系统',
  ogImage = '/og-default.svg',
  canonical,
  type = 'website',
  publishedTime,
} = Astro.props;
const pathname = Astro.url.pathname;

// 拼接完整页面标题与规范 URL
const fullTitle = title ? `${title} - ${SITE_NAME}` : `${SITE_NAME} · 系统化股票学习`;
const canonicalURL = new URL(canonical || pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

const navItems = [
  { label: '首页', href: '/', active: pathname === '/' },
  { label: 'Mistery 秘籍', href: '/tutorials/mjie-00-chapter-index', active: pathname.startsWith('/tutorials/mjie-') || pathname === '/tutorials/mistery-map' || pathname === '/tutorials/mistery-map/' },
  { label: '教程', href: '/tutorials', active: pathname === '/tutorials' || pathname === '/tutorials/' },
  { label: '技术指标', href: '/tutorials?cat=技术指标', active: false, cat: '技术指标' },
  { label: '行业研究', href: '/tutorials?cat=行业研究', active: false, cat: '行业研究' },
  { label: '交易系统', href: '/tutorials?cat=交易系统', active: false, cat: '交易系统' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title || SITE_NAME} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || SITE_NAME} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- RSS 自动发现 -->
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />
  </head>
  <body class="min-h-screen text-slate-950 antialiased">
    <a href="#main-content" class="skip-link">跳到正文</a>
    <nav class="site-nav">
      <div class="site-shell h-[68px] flex items-center justify-between gap-6">
        <a href="/" class="brand-link" aria-label="股票学习站首页">
          <span class="brand-mark" aria-hidden="true">SL</span>
          <span class="brand-text">股票学习站</span>
        </a>
        <div class="hidden md:flex items-center gap-1 rounded-full border border-slate-200/70 bg-white/70 p-1 shadow-sm shadow-slate-900/5">
          {navItems.map((item) => {
            return (
              <a
                href={item.href}
                data-nav-cat={item.cat ?? undefined}
                class={`nav-pill ${item.active ? 'nav-pill-active' : ''}`}
              >
                {item.label}
              </a>
            );
          })}
        </div>
        <button id="mobile-menu-btn" class="md:hidden nav-menu-button" aria-label="打开菜单" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white/95 backdrop-blur-xl">
        <div class="site-shell py-3 grid gap-1">
          {navItems.map((item) => (
            <a href={item.href} class="rounded-xl px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main id="main-content" class="site-shell py-8 md:py-10">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-shell py-8 md:py-10">
        <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <div class="flex items-center gap-2 text-sm font-semibold text-slate-800">
              <span class="brand-mark brand-mark-small" aria-hidden="true">SL</span>
              股票学习站
            </div>
            <p class="mt-2 max-w-xl text-sm text-slate-500">系统化学习投资知识，建立自己的分析框架、交易计划和风险控制纪律。</p>
          </div>
          <p class="max-w-xl text-xs leading-relaxed text-slate-500 md:text-right">
            本站内容仅供学习交流，不构成投资建议。投资有风险，入市需谨慎。
          </p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isHidden));
      });

      // 按当前 ?cat= 高亮对应分类导航项（静态站点拿不到 query，故客户端补）
      const currentCat = new URLSearchParams(window.location.search).get('cat');
      if (currentCat) {
        document
          .querySelectorAll<HTMLAnchorElement>('[data-nav-cat]')
          .forEach((el) => {
            if (el.dataset.navCat === currentCat) el.classList.add('nav-pill-active');
          });
      }
    </script>
  </body>
</html>
