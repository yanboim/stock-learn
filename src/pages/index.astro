---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort((a, b) => {
  if (a.data.category !== b.data.category) return a.data.category.localeCompare(b.data.category);
  return a.data.order - b.data.order;
});

// Group by category
const categories = [...new Set(tutorials.map((t) => t.data.category))];
const categoryIcons: Record<string, string> = {
  '技术指标': '📊',
  '基础入门': '🎓',
  '行业研究': '🏭',
  '交易系统': '📋',
  '实战案例': '📈',
  '风险控制': '⚠️',
};
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="text-center py-16">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
      📈 股票学习站
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
      系统化学习股票投资：技术分析、行业研究、交易系统
    </p>
    <p class="text-sm text-gray-400 mb-8">
      每篇教程配有交互式图表和可视化信息图，让知识更直观
    </p>
    <div class="flex justify-center gap-4">
      <a href="/tutorials" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition">
        开始学习 →
      </a>
    </div>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
    <div class="text-center p-4 bg-white rounded-xl border border-gray-200">
      <div class="text-2xl font-bold text-blue-600">{tutorials.length}</div>
      <div class="text-sm text-gray-500">篇教程</div>
    </div>
    <div class="text-center p-4 bg-white rounded-xl border border-gray-200">
      <div class="text-2xl font-bold text-green-600">{categories.length}</div>
      <div class="text-sm text-gray-500">个分类</div>
    </div>
    <div class="text-center p-4 bg-white rounded-xl border border-gray-200">
      <div class="text-2xl font-bold text-purple-600">交互式</div>
      <div class="text-sm text-gray-500">学习体验</div>
    </div>
    <div class="text-center p-4 bg-white rounded-xl border border-gray-200">
      <div class="text-2xl font-bold text-orange-600">免费</div>
      <div class="text-sm text-gray-500">永久开放</div>
    </div>
  </section>

  <!-- Categories & Tutorials -->
  {categories.map((cat) => (
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
        <span>{categoryIcons[cat] || '📚'}</span>
        <span>{cat}</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {sortedTutorials
          .filter((t) => t.data.category === cat)
          .map((tutorial) => (
            <a
              href={`/tutorials/${tutorial.id}`}
              class="group block p-5 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-blue-50 text-blue-600 font-medium">
                  {tutorial.data.difficulty}
                </span>
              </div>
              <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition mb-2">
                {tutorial.data.title}
              </h3>
              <p class="text-sm text-gray-500 line-clamp-2">
                {tutorial.data.description}
              </p>
            </a>
          ))}
      </div>
    </section>
  ))}

  <!-- Feature highlight -->
  <section class="mt-16 p-8 bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl border border-blue-100">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">✨ 本站特色</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="text-center">
        <div class="text-4xl mb-2">📊</div>
        <h3 class="font-semibold text-gray-800 mb-1">交互式K线图</h3>
        <p class="text-sm text-gray-500">每篇指标教程配真实K线演示，可以切换参数实时查看效果</p>
      </div>
      <div class="text-center">
        <div class="text-4xl mb-2">🖼️</div>
        <h3 class="font-semibold text-gray-800 mb-1">可视化信息图</h3>
        <p class="text-sm text-gray-500">复杂概念用精美长图呈现，一眼看懂核心逻辑</p>
      </div>
      <div class="text-center">
        <div class="text-4xl mb-2">⚖️</div>
        <h3 class="font-semibold text-gray-800 mb-1">对比分析表</h3>
        <p class="text-sm text-gray-500">不同指标、不同策略的交互对比，帮助深入理解差异</p>
      </div>
    </div>
  </section>
</BaseLayout>
