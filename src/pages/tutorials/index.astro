---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const allCategories = ['基础入门', '技术指标', '行业研究', '交易系统', '风险控制', '实战案例'];
const sortedTutorials = tutorials.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const categoryLabels: Record<string, string> = {
  '技术指标': '指标',
  '基础入门': '入门',
  '行业研究': '研究',
  '交易系统': '系统',
  '实战案例': '案例',
  '风险控制': '风控',
};

const difficultyColors: Record<string, string> = {
  '入门': 'difficulty-beginner',
  '进阶': 'difficulty-advanced',
  '高级': 'difficulty-hard',
};
---

<BaseLayout title="教程列表 - 股票学习站">
  <section class="list-hero">
    <p class="section-kicker">Lessons</p>
    <h1 id="tutorial-list-title">教程列表</h1>
    <p id="tutorial-list-desc">系统化学习股票投资知识，从入门到进阶。</p>
  </section>

  <div class="filter-bar" aria-label="教程分类筛选">
    <a href="/tutorials" data-category-filter="" class="category-filter is-active">全部</a>
    {allCategories.map((category) => (
      <a href={`/tutorials?cat=${encodeURIComponent(category)}`} data-category-filter={category} class="category-filter">
        {category}
      </a>
    ))}
  </div>

  <div class="tutorial-list-grid">
    {sortedTutorials.map((tutorial) => (
      <a href={`/tutorials/${tutorial.id}`} data-tutorial-card data-category={tutorial.data.category} class="tutorial-list-card">
        <div class="tutorial-card-topline">
          <span class="category-chip">{categoryLabels[tutorial.data.category] || tutorial.data.category}</span>
          <span class={`difficulty-chip ${difficultyColors[tutorial.data.difficulty] || 'difficulty-default'}`}>
            {tutorial.data.difficulty}
          </span>
        </div>
        <h2>{tutorial.data.title}</h2>
        <p>{tutorial.data.description}</p>
        <div class="tag-row">
          {tutorial.data.tags.slice(0, 4).map((tag) => (
            <span>#{tag}</span>
          ))}
        </div>
        <div class="card-footer-line">
          <span>{tutorial.data.publishDate.toLocaleDateString('zh-CN')}</span>
          <strong>阅读</strong>
        </div>
      </a>
    ))}
  </div>

  <div id="empty-category-state" class="hidden empty-state">
    <div class="empty-state-mark">0</div>
    <p id="empty-category-text">该分类下暂无教程</p>
    <a href="/tutorials">查看全部教程</a>
  </div>

  <script define:vars={{ categoryLabels }}>
    function setButtonState(button, active) {
      button.classList.toggle('is-active', active);
    }

    function applyCategoryFilter(category, updateUrl = false) {
      const cards = Array.from(document.querySelectorAll('[data-tutorial-card]'));
      const buttons = Array.from(document.querySelectorAll('[data-category-filter]'));
      const title = document.getElementById('tutorial-list-title');
      const desc = document.getElementById('tutorial-list-desc');
      const emptyState = document.getElementById('empty-category-state');
      const emptyText = document.getElementById('empty-category-text');

      let visibleCount = 0;
      cards.forEach((card) => {
        const matched = !category || card.dataset.category === category;
        card.classList.toggle('is-filtered-out', !matched);
        if (matched) visibleCount += 1;
      });

      buttons.forEach((button) => {
        setButtonState(button, (button.dataset.categoryFilter || '') === category);
      });

      if (title) title.textContent = category || '教程列表';
      if (desc) {
        desc.textContent = category
          ? `当前显示「${category}」分类，共 ${visibleCount} 篇教程。`
          : '系统化学习股票投资知识，从入门到进阶。';
      }
      if (emptyState) emptyState.classList.toggle('hidden', visibleCount !== 0);
      if (emptyText) emptyText.textContent = category ? `「${category}」分类下暂无教程` : '教程正在编写中';

      if (updateUrl) {
        const url = category ? `/tutorials?cat=${encodeURIComponent(category)}` : '/tutorials';
        history.pushState({ category }, '', url);
      }
    }

    const params = new URLSearchParams(window.location.search);
    applyCategoryFilter(params.get('cat') || '');

    document.querySelectorAll('[data-category-filter]').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        applyCategoryFilter(link.dataset.categoryFilter || '', true);
      });
    });

    window.addEventListener('popstate', () => {
      const params = new URLSearchParams(window.location.search);
      applyCategoryFilter(params.get('cat') || '');
    });
  </script>
</BaseLayout>
