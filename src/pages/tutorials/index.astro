---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const categoryIcons: Record<string, string> = {
  '技术指标': '📊',
  '基础入门': '🎓',
  '行业研究': '🏭',
  '交易系统': '📋',
  '实战案例': '📈',
  '风险控制': '⚠️',
};

const difficultyColors: Record<string, string> = {
  '入门': 'bg-green-100 text-green-700',
  '进阶': 'bg-yellow-100 text-yellow-700',
  '高级': 'bg-red-100 text-red-700',
};
---

<BaseLayout title="教程列表 - 股票学习站">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">📚 教程列表</h1>
  <p class="text-gray-500 mb-8">系统化学习股票投资知识，从入门到进阶</p>

  <div class="space-y-4">
    {sortedTutorials.map((tutorial) => (
      <a
        href={`/tutorials/${tutorial.id}`}
        class="group block p-5 bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all"
      >
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-lg">{categoryIcons[tutorial.data.category] || '📚'}</span>
              <span class="text-sm text-gray-500">{tutorial.data.category}</span>
              <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${difficultyColors[tutorial.data.difficulty] || 'bg-gray-100 text-gray-600'}`}>
                {tutorial.data.difficulty}
              </span>
            </div>
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition">
              {tutorial.data.title}
            </h2>
            <p class="text-sm text-gray-500 mt-1">{tutorial.data.description}</p>
            <div class="flex gap-2 mt-2">
              {tutorial.data.tags.map((tag) => (
                <span class="text-xs text-gray-400">#{tag}</span>
              ))}
            </div>
          </div>
          <div class="text-sm text-gray-400 flex-shrink-0">
            {tutorial.data.publishDate.toLocaleDateString('zh-CN')}
          </div>
        </div>
      </a>
    ))}
  </div>

  {sortedTutorials.length === 0 && (
    <div class="text-center py-16 text-gray-400">
      <div class="text-6xl mb-4">📝</div>
      <p>教程正在编写中，敬请期待...</p>
    </div>
  )}
</BaseLayout>
