---
export interface Props {
  title: string;
  description: string;
  category: string;
  difficulty?: string;
  publishDate: Date;
  tags?: string[];
  icon?: string;
}

const { title, description, category, difficulty, publishDate, tags = [], icon = '📊' } = Astro.props;

const categoryConfig: Record<string, { color: string; defaultIcon: string }> = {
  '基础入门': { color: 'banner-blue', defaultIcon: '📚' },
  '技术指标': { color: 'banner-purple', defaultIcon: '📈' },
  '行业研究': { color: 'banner-orange', defaultIcon: '🏭' },
  '交易系统': { color: 'banner-teal', defaultIcon: '⚙️' },
  '实战案例': { color: 'banner-pink', defaultIcon: '🎯' },
  '风险控制': { color: 'banner-red', defaultIcon: '🛡️' },
};

const config = categoryConfig[category] || { color: 'banner-blue', defaultIcon: '📊' };
const displayIcon = icon !== '📊' ? icon : config.defaultIcon;

const difficultyColors: Record<string, string> = {
  '入门': 'bg-white/20 text-white',
  '进阶': 'bg-white/20 text-white',
  '高级': 'bg-white/20 text-white',
};
---

<div class={`tutorial-banner ${config.color}`}>
  <span class="banner-icon">{displayIcon}</span>
  <div class="flex flex-wrap gap-2 mb-3" style="position:relative;z-index:1">
    <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/20 text-white backdrop-blur-sm">
      {category}
    </span>
    {difficulty && (
      <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${difficultyColors[difficulty] || 'bg-white/20 text-white'}`}>
        {difficulty}
      </span>
    )}
    {tags.slice(0, 3).map((tag) => (
      <span class="px-2.5 py-0.5 rounded-full text-xs bg-white/15 text-white/90">
        #{tag}
      </span>
    ))}
  </div>
  <h1>{title}</h1>
  <p>{description}</p>
  <div class="text-sm text-white/70 mt-3" style="position:relative;z-index:1">
    发布于 {publishDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
  </div>
</div>
