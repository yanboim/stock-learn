---
export interface Props {
  title: string;
  description: string;
  category: string;
  difficulty?: string;
  publishDate: Date;
  tags?: string[];
}

const { title, description, category, difficulty, publishDate, tags = [] } = Astro.props;

const difficultyColors: Record<string, string> = {
  '入门': 'bg-green-100 text-green-700',
  '进阶': 'bg-yellow-100 text-yellow-700',
  '高级': 'bg-red-100 text-red-700',
};

const categoryColors: Record<string, string> = {
  '技术指标': 'bg-blue-100 text-blue-700',
  '基础入门': 'bg-purple-100 text-purple-700',
  '行业研究': 'bg-orange-100 text-orange-700',
  '交易系统': 'bg-teal-100 text-teal-700',
  '实战案例': 'bg-pink-100 text-pink-700',
  '风险控制': 'bg-red-100 text-red-700',
};
---

<article class="tutorial-meta">
  <div class="flex flex-wrap gap-2 mb-4">
    <span class={`px-3 py-1 rounded-full text-sm font-medium ${categoryColors[category] || 'bg-gray-100 text-gray-700'}`}>
      {category}
    </span>
    {difficulty && (
      <span class={`px-3 py-1 rounded-full text-sm font-medium ${difficultyColors[difficulty] || 'bg-gray-100 text-gray-700'}`}>
        {difficulty}
      </span>
    )}
    {tags.map((tag) => (
      <span class="px-3 py-1 rounded-full text-sm bg-gray-100 text-gray-600">
        #{tag}
      </span>
    ))}
  </div>
  <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
  <p class="text-lg text-gray-600 mb-4">{description}</p>
  <div class="text-sm text-gray-400">
    发布于 {publishDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
  </div>
</article>
